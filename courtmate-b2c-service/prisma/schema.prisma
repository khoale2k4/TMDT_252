generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid()) @db.Uuid
  email      String    @unique
  password   String
  full_name  String
  phone      String?
  role       String    @default("user") // "user", "owner", "admin"
  avatar_url String?
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  // Relations
  venues     Venue[]   @relation("OwnerVenues")

  @@map("users")
}

model Venue {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  address         String
  lat             Float
  lng             Float
  sport_types     String[]
  amenities       String[]
  min_price       Int
  max_price       Int
  rating_avg      Float    @default(0)
  total_reviews   Int      @default(0)
  cover_image_url String?
  owner_id        String?  @db.Uuid // Nullable cho những venue cũ
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // THÊM DÒNG NÀY ĐỂ LIÊN KẾT:
  courts          Court[] 
  owner           User?    @relation("OwnerVenues", fields: [owner_id], references: [id], onDelete: SetNull) 

  @@map("venues")
}

// THÊM BẢNG COURT
model Court {
  id         String   @id @default(uuid()) @db.Uuid
  venue_id   String   @db.Uuid
  name       String
  sport_type String
  image_url  String?
  slots      Slot[]

  venue      Venue    @relation(fields: [venue_id], references: [id], onDelete: Cascade)

  @@map("courts")
}

// THÊM BẢNG SLOT
model Slot {
  id         String   @id @default(uuid()) @db.Uuid
  court_id   String   @db.Uuid
  date       String   // Lưu kiểu "YYYY-MM-DD" cho dễ query
  start_time String   // VD: "08:00"
  end_time   String   // VD: "09:00"
  status     String   // "available", "booked", "locked"
  price      Int
  version    Int      @default(1)

  locked_by    String?   @db.Uuid // ID của user đang giữ slot
  locked_until DateTime? // Thời gian hết hạn khóa

  lock_token   String?   // Dùng để đối chiếu lúc checkout
  booking_id   String?   @db.Uuid

  court      Court    @relation(fields: [court_id], references: [id], onDelete: Cascade)
  booking      Booking?  @relation(fields: [booking_id], references: [id])

  @@map("slots")
}


model Booking {
  id                  String    @id @default(uuid()) @db.Uuid
  user_id             String    @db.Uuid
  venue_id            String?   @db.Uuid
  status              String    // "pending_payment", "paid", "cancelled"
  payment_method      String
  total_amount        Int
  final_amount        Int?
  discount_amount     Int?      @default(0)
  tax_amount          Int?      @default(0)
  notes               String?
  recurring_frequency String?
  recurring_group_id  String?   @db.Uuid
  created_at          DateTime  @default(now())
  updated_at          DateTime? @updatedAt

  slots          Slot[]
  review         Review?
  invoice        Invoice?

  @@map("bookings")
}

model Review {
  id          String   @id @default(uuid()) @db.Uuid
  booking_id  String   @unique @db.Uuid
  user_id     String   @db.Uuid
  venue_id    String   @db.Uuid
  rating      Int
  comment     String?
  created_at  DateTime @default(now())

  booking     Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model UserActivity {
  id          String   @id @default(uuid())
  user_id     String
  date        String   // YYYY-MM-DD
  matches     Int      @default(0)
  check_ins   Int      @default(0)

  @@unique([user_id, date])
  @@map("user_activities")
}

model UserStat {
  user_id         String   @id
  elo_rating      Int      @default(1200)
  total_matches   Int      @default(0)
  level           String   @default("Beginner")
  milestones      String[] 
  
  @@map("user_stats")
}

model Lobby {
  id              String   @id @default(uuid())
  creator_id      String
  venue_id        String
  court_id        String
  slot_id         String
  sport_type      String
  required_level  String   @default("Any") // "Beginner", "Intermediate", "Advanced"
  target_players  Int      @default(4)
  current_players Int      @default(1)
  status          String   @default("waiting") // "waiting", "matched", "cancelled"
  total_price     Int
  split_price     Int
  created_at      DateTime @default(now())

  members         LobbyMember[]

  @@map("lobbies")
}

model LobbyMember {
  id          String   @id @default(uuid())
  lobby_id    String
  user_id     String
  status      String   @default("joined") // "joined", "paid", "left"
  joined_at   DateTime @default(now())

  lobby       Lobby    @relation(fields: [lobby_id], references: [id], onDelete: Cascade)

  @@map("lobby_members")
}

model Invoice {
  id              String   @id @default(uuid()) @db.Uuid
  booking_id      String   @unique @db.Uuid
  misa_invoice_no String?  @db.VarChar(100)
  pdf_url         String?
  status          String   @default("issued") @db.VarChar(50)
  issued_at       DateTime @default(now())

  booking         Booking  @relation(fields: [booking_id], references: [id])

  @@map("invoices")
}
