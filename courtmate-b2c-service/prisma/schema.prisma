generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  full_name  String
  phone      String?
  role       String   @default("user") // "user", "owner", "admin"
  created_at DateTime @default(now())

  // Relations
  venues     Venue[]  @relation("OwnerVenues")
}

model Venue {
  id              String   @id @default(uuid())
  name            String
  address         String
  lat             Float
  lng             Float
  sport_types     String[]
  amenities       String[]
  min_price       Int
  max_price       Int
  rating_avg      Float    @default(0)
  total_reviews   Int      @default(0)
  cover_image_url String?
  owner_id        String?  // Nullable cho những venue cũ
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // THÊM DÒNG NÀY ĐỂ LIÊN KẾT:
  courts          Court[] 
  owner           User?    @relation("OwnerVenues", fields: [owner_id], references: [id], onDelete: SetNull) 

  @@map("Venue")
}

// THÊM BẢNG COURT
model Court {
  id         String   @id @default(uuid())
  venue_id   String
  name       String
  sport_type String
  image_url  String?
  slots      Slot[]

  venue      Venue    @relation(fields: [venue_id], references: [id], onDelete: Cascade)

  @@map("Court")
}

// THÊM BẢNG SLOT
model Slot {
  id         String   @id @default(uuid())
  court_id   String
  date       String   // Lưu kiểu "YYYY-MM-DD" cho dễ query
  start_time String   // VD: "08:00"
  end_time   String   // VD: "09:00"
  status     String   // "available", "booked", "locked"
  price      Int
  version    Int      @default(1)

  locked_by    String?   // ID của user đang giữ slot
  locked_until DateTime? // Thời gian hết hạn khóa

  lock_token   String?   // Dùng để đối chiếu lúc checkout
  booking_id   String?

  court      Court    @relation(fields: [court_id], references: [id], onDelete: Cascade)
  booking      Booking?  @relation(fields: [booking_id], references: [id])

  @@map("Slot")
}


model Booking {
  id             String   @id @default(uuid())
  user_id        String
  status         String   // "pending_payment", "paid", "cancelled"
  payment_method String
  total_amount   Int
  created_at     DateTime @default(now())

  slots          Slot[]
  review         Review?

  @@map("Booking")
}

model Review {
  id          String   @id @default(uuid())
  booking_id  String   @unique
  user_id     String
  venue_id    String
  rating      Int
  comment     String?
  created_at  DateTime @default(now())

  booking     Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@map("Review")
}

model UserActivity {
  id          String   @id @default(uuid())
  user_id     String
  date        String   // YYYY-MM-DD
  matches     Int      @default(0)
  check_ins   Int      @default(0)

  @@unique([user_id, date])
  @@map("user_activities")
}

model UserStat {
  user_id         String   @id
  elo_rating      Int      @default(1200)
  total_matches   Int      @default(0)
  level           String   @default("Beginner")
  milestones      String[] 
  
  @@map("user_stats")
}

model Lobby {
  id              String   @id @default(uuid())
  creator_id      String
  venue_id        String
  court_id        String
  slot_id         String
  sport_type      String
  required_level  String   @default("Any") // "Beginner", "Intermediate", "Advanced"
  target_players  Int      @default(4)
  current_players Int      @default(1)
  status          String   @default("waiting") // "waiting", "matched", "cancelled"
  total_price     Int
  split_price     Int
  created_at      DateTime @default(now())

  members         LobbyMember[]

  @@map("lobbies")
}

model LobbyMember {
  id          String   @id @default(uuid())
  lobby_id    String
  user_id     String
  status      String   @default("joined") // "joined", "paid", "left"
  joined_at   DateTime @default(now())

  lobby       Lobby    @relation(fields: [lobby_id], references: [id], onDelete: Cascade)

  @@map("lobby_members")
}
